# ── API Keys (dejar vacío = modo mock automático) ─────────────────────────────
ANTHROPIC_API_KEY=
TAVILY_API_KEY=
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@tudominio.com

# ── Puertos (solo desarrollo local) ──────────────────────────────────────────
# AGENT_SERVER_PORT: puerto del backend Express + WS (ahora en el mismo puerto)
# WS_PORT ya no se usa — WS corre en el mismo puerto que HTTP (/ws)
AGENT_SERVER_PORT=3001

# ── Frontend (desarrollo local) ───────────────────────────────────────────────
# En dev, dejar VACÍOS — el proxy de Vite redirige /api → :3001 y /ws → :3001/ws
# En producción, apuntar al backend desplegado en Railway:
#   VITE_API_URL=https://multi-agentes-abrinay.up.railway.app
#   VITE_WS_URL=wss://multi-agentes-abrinay.up.railway.app/ws
VITE_API_URL=
VITE_WS_URL=

# ── Entorno ────────────────────────────────────────────────────────────────────
NODE_ENV=development

# ── Notas de deploy ────────────────────────────────────────────────────────────
# GitHub Pages (frontend):
#   Configura en GitHub → Settings → Secrets and variables → Actions:
#   - VITE_API_URL  (URL Railway sin /api)
#   - VITE_WS_URL   (URL Railway con wss:// y /ws)
#
# Railway (backend):
#   Configura las variables de arriba en el dashboard de Railway.
#   Railway inyecta $PORT automáticamente — no configurar PORT.
